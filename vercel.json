{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "package.json", "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/api/py/(.*)", "dest": "api/index.py" },
    { "src": "/api/(siniestros|stats|proveedores|asegurados|red|evaluar|upload)(.*)", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
